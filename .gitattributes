# Repository line-ending policy:
# - keep text files normalized as LF in the repo and working tree
# - make shell/Python files safe for Unix runtimes
# - avoid platform-specific CRLF noise in diffs on Windows

* text=auto

*.ps1 text eol=lf
*.psm1 text eol=lf
*.sh text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
.gitignore text eol=lf
.npmignore text eol=lf
.editorconfig text eol=lf
VERSION text eol=lf

*.png binary
