{
  "name": "garda-agent-orchestrator",
  "version": "1.0.0",
  "description": "Governed local runtime for AI coding agents with task lifecycle, mandatory gates, reviews, and auditable completion.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shubchynskyi/garda-agent-orchestrator.git"
  },
  "homepage": "https://garda-workflow.netlify.app/",
  "bugs": {
    "url": "https://github.com/Shubchynskyi/garda-agent-orchestrator/issues"
  },
  "author": "Dmytro Shubchynskyi <d.shubchynskyi@gmail.com>",
  "license": "Apache-2.0",
  "type": "commonjs",
  "bin": {
    "garda": "bin/garda.js",
    "gao": "bin/garda.js",
    "garda-agent-orchestrator": "bin/garda.js"
  },
  "scripts": {
    "build:scripts": "node scripts/node-foundation/build-scripts.cjs build.js sync-repo-cli",
    "build": "node scripts/node-foundation/build-scripts.cjs build.js publish-runtime",
    "build:publish-runtime": "node scripts/node-foundation/build-scripts.cjs build.js publish-runtime",
    "build:node-foundation": "node scripts/node-foundation/build-scripts.cjs build.js node-foundation",
    "test": "node scripts/node-foundation/build-scripts.cjs test.js",
    "test:node-foundation": "node scripts/node-foundation/build-scripts.cjs test.js",
    "validate:version-parity": "node scripts/node-foundation/build-scripts.cjs validate-release.js",
    "lint": "eslint \"src/**/*.ts\" \"tests/node/**/*.ts\" \"scripts/node-foundation/**/*.ts\"",
    "coverage": "c8 --reporter=text --reporter=lcov npm test",
    "audit:prod": "npm audit --omit=dev",
    "audit:all": "npm audit",
    "quality": "npm run typecheck && npm run lint && npm run coverage && npm run audit:prod",
    "validate:release": "npm run validate:version-parity && npm run build && npm run quality && node --test .node-build/tests/node/packaging/pack-smoke.test.js",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.node-foundation.json",
    "prepack": "npm run build:publish-runtime"
  },
  "files": [
    ".gitattributes",
    "bin",
    "dist",
    "src",
    "tsconfig.json",
    "tsconfig.node-foundation.json",
    "template",
    "AGENT_INIT_PROMPT.md",
    "CHANGELOG.md",
    "HOW_TO.md",
    "LICENSE",
    "NOTICE",
    "TRADEMARKS.md",
    "MANIFEST.md",
    "README.md",
    "SECURITY.md",
    "VERSION"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "c8": "^11.0.0",
    "eslint": "^10.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "garda",
    "cli",
    "typescript",
    "ai-agents",
    "coding-agents",
    "ai-coding",
    "agent-orchestration",
    "ai-orchestration",
    "agentic-workflow",
    "quality-gates",
    "ai-governance",
    "agent-governance",
    "code-review",
    "audit-trail",
    "claude-workflow",
    "codex-workflow",
    "gemini-workflow",
    "qwen-workflow",
    "github-copilot"
  ]
}
